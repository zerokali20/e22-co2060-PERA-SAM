{
    "routes": [
        {
            "route": "/*",
            "serve": "/index.html",
            "statusCode": 200
        }
    ],
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/assets/*",
            "/*.{css,js,png,jpg,svg,ico}"
        ]
    },
    "mimeTypes": {
        ".json": "application/json"
    }
}